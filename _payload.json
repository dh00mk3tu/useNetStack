[{"data":1,"prerenderedAt":266},["ShallowReactive",2],{"content-query-1DxZ1vYQk5":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":5,"title":7,"description":8,"body":9,"_type":260,"_id":261,"_source":262,"_file":263,"_stem":264,"_extension":265},"/","",false,"useNetStack","Designed, developed and delivered with \u003C3 by Anirudh Rath | dh00mk3tu",{"type":10,"children":11,"toc":250},"root",[12,20,24,29,36,41,46,51,56,68,78,88,91,97,108,129,138,151,163,171,184,195,203,208,216,221,226],{"type":13,"tag":14,"props":15,"children":17},"element","h1",{"id":16},"usenetstack",[18],{"type":19,"value":7},"text",{"type":13,"tag":21,"props":22,"children":23},"hr",{},[],{"type":13,"tag":25,"props":26,"children":27},"p",{},[28],{"type":19,"value":8},{"type":13,"tag":30,"props":31,"children":33},"h2",{"id":32},"why-did-i-make-this",[34],{"type":19,"value":35},"Why did I make this?",{"type":13,"tag":25,"props":37,"children":38},{},[39],{"type":19,"value":40},"Jumping onto any new technology, framework or library tto build apps etc is a challenge in itself. After a certain while, you hit the blocker that how do we make API calls in this environment; because naturally you have to consume data from the network at some point. Eventually you end up watching tutorials and reading documentation, but there is still no structure to it.",{"type":13,"tag":25,"props":42,"children":43},{},[44],{"type":19,"value":45},"This composable helps to provide you with that structure.",{"type":13,"tag":25,"props":47,"children":48},{},[49],{"type":19,"value":50},"I'm calling it a composable in general and not just in the terms of NUXT. It is a utility method for you that provides you a with very granular and precise control over your network calls.",{"type":13,"tag":25,"props":52,"children":53},{},[54],{"type":19,"value":55},"Let's discuss what's there to offer and you'll know whether you need this or not by looking at this quick example.",{"type":13,"tag":57,"props":58,"children":60},"h3",{"id":59},"features",[61],{"type":13,"tag":62,"props":63,"children":65},"a",{"href":64},"/features",[66],{"type":19,"value":67},"Features",{"type":13,"tag":57,"props":69,"children":71},{"id":70},"documentation",[72],{"type":13,"tag":62,"props":73,"children":75},{"href":74},"/documentation",[76],{"type":19,"value":77},"Documentation",{"type":13,"tag":57,"props":79,"children":81},{"id":80},"usenetstack-playground",[82],{"type":13,"tag":62,"props":83,"children":85},{"href":84},"/playground",[86],{"type":19,"value":87},"useNetStack - Playground",{"type":13,"tag":21,"props":89,"children":90},{},[],{"type":13,"tag":57,"props":92,"children":94},{"id":93},"quick-example",[95],{"type":19,"value":96},"Quick Example",{"type":13,"tag":25,"props":98,"children":99},{},[100,106],{"type":13,"tag":101,"props":102,"children":104},"code",{"className":103},[],[105],{"type":19,"value":7},{"type":19,"value":107}," can make network calls for you, in a clean and intuitive manner. It can help you structure your API calls, provide you with logs when you need them and solid control of each individual call as well. Let's start by making a normal API call.",{"type":13,"tag":25,"props":109,"children":110},{},[111,113,119,121,127],{"type":19,"value":112},"After importing ",{"type":13,"tag":101,"props":114,"children":116},{"className":115},[],[117],{"type":19,"value":118},"useNetStack()",{"type":19,"value":120},", you'll find that it exports a method called ",{"type":13,"tag":101,"props":122,"children":124},{"className":123},[],[125],{"type":19,"value":126},"executeCall",{"type":19,"value":128}," . This method allows us to make our API calls and provides us with all the options that are required for granular control over our call.",{"type":13,"tag":25,"props":130,"children":131},{},[132],{"type":13,"tag":133,"props":134,"children":137},"img",{"alt":135,"src":136},"Importing Method","/importingmethod.png",[],{"type":13,"tag":139,"props":140,"children":146},"pre",{"className":141,"code":143,"filename":144,"language":145,"meta":5},[142],"language-ts","const { executeCall } = useNetStack();\n\nconst result = await executeCall({\n  apiRequest: {\n    method: 'GET',\n    endpoint: '/api/products',\n  },\n});\n","api_call.ts","ts",[147],{"type":13,"tag":101,"props":148,"children":149},{"__ignoreMap":5},[150],{"type":19,"value":143},{"type":13,"tag":25,"props":152,"children":153},{},[154,156,161],{"type":19,"value":155},"Now, ",{"type":13,"tag":101,"props":157,"children":159},{"className":158},[],[160],{"type":19,"value":126},{"type":19,"value":162}," accepts an argument which is an object. Now this object accepts a number a typed arguments, as shown in the image below.",{"type":13,"tag":25,"props":164,"children":165},{},[166],{"type":13,"tag":133,"props":167,"children":170},{"alt":168,"src":169},"Screenshot from 2024-10-12 18-45-22.png","/22.png",[],{"type":13,"tag":25,"props":172,"children":173},{},[174,176,182],{"type":19,"value":175},"Now, there is one ",{"type":13,"tag":101,"props":177,"children":179},{"className":178},[],[180],{"type":19,"value":181},"param",{"type":19,"value":183}," which is required, while rest are optional.",{"type":13,"tag":25,"props":185,"children":186},{},[187,193],{"type":13,"tag":101,"props":188,"children":190},{"className":189},[],[191],{"type":19,"value":192},"apiRequest",{"type":19,"value":194}," is a required parameter which is an object, and this object also requires certain mandatory parameters. Let's use it and see what options are available to us.",{"type":13,"tag":25,"props":196,"children":197},{},[198],{"type":13,"tag":133,"props":199,"children":202},{"alt":200,"src":201},"Screenshot from 2024-10-12 18-53-14.png","/14.png",[],{"type":13,"tag":25,"props":204,"children":205},{},[206],{"type":19,"value":207},"Notice, that the required keys have pretty self explanatory names, let's add these required parameters.",{"type":13,"tag":25,"props":209,"children":210},{},[211],{"type":13,"tag":133,"props":212,"children":215},{"alt":213,"src":214},"Screenshot_20241012_192602.png","/Screenshot_20241012_192602.png",[],{"type":13,"tag":25,"props":217,"children":218},{},[219],{"type":19,"value":220},"We can select the type of our API method, and specify the API endpoint.",{"type":13,"tag":25,"props":222,"children":223},{},[224],{"type":19,"value":225},"Now all you have to do is play around with the result that you get from the endpoint.",{"type":13,"tag":25,"props":227,"children":228},{},[229,231,235,237,242,244,248],{"type":19,"value":230},"Head over to ",{"type":13,"tag":62,"props":232,"children":233},{"href":64},[234],{"type":19,"value":67},{"type":19,"value":236}," to read more about the ",{"type":13,"tag":101,"props":238,"children":240},{"className":239},[],[241],{"type":19,"value":7},{"type":19,"value":243}," or head to ",{"type":13,"tag":62,"props":245,"children":246},{"href":74},[247],{"type":19,"value":77},{"type":19,"value":249}," if you're ready to get started.",{"title":5,"searchDepth":251,"depth":251,"links":252},2,[253],{"id":32,"depth":251,"text":35,"children":254},[255,257,258,259],{"id":59,"depth":256,"text":67},3,{"id":70,"depth":256,"text":77},{"id":80,"depth":256,"text":87},{"id":93,"depth":256,"text":96},"markdown","content:index.md","content","index.md","index","md",1729193006011]